DB_NAME=astroswarm
DB_USER=astroswarm
DB_PASSWORD=changeme

DATABASE_URL=postgresql+psycopg2://astroswarm:changeme@db:5432/astroswarm

UPLOAD_DIR=/app/uploads

PORT=5050

FRONTEND_ORIGIN=http://localhost:5173

API_URL=http://localhost:5050
PUBLIC_API_URL=http://localhost:5050
API_SECRET_KEY=dev_secret_key

# Evaluation worker(s). The worker pulls queued FARP benchmark jobs and runs the
# Godot dedicated server locally. Drop the exported build into web/server_build/.
# WORKER_SERVER_URL is how the worker reaches the server (internal name in Docker,
# or a public URL when running a worker on another machine).
WORKER_SERVER_URL=http://server:5050
WORKER_NAME=worker
# Max Godot processes a single worker runs in parallel (set per machine).
WORKER_MAX_JOBS=4
GODOT_SERVER_BIN=/app/server_build/AstroSwarm_Linux.x86_64
GODOT_PCK=
EVAL_TIMEOUT_SECONDS=1800
EVAL_FIXED_FPS=60
