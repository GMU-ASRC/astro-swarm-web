DB_NAME=astroswarm
DB_USER=astroswarm
DB_PASSWORD=changeme

DATABASE_URL=postgresql+psycopg2://astroswarm:changeme@db:5432/astroswarm

UPLOAD_DIR=/app/uploads

PORT=5050

FRONTEND_ORIGIN=http://localhost:5173

API_URL=http://localhost:5050
PUBLIC_API_URL=http://localhost:5050
API_SECRET_KEY=dev_secret_key

# Server: how many work shards each evaluation is split into. Shards are claimed
# by workers up to their capacity, so this should comfortably exceed the total
# parallel-job capacity of your worker fleet for even load balancing.
EVAL_SHARD_COUNT=32

# Evaluation worker(s). The worker pulls queued FARP benchmark jobs and runs the
# Godot dedicated server locally. On startup it downloads the AstroSwarm_Linux_Server.zip
# asset from the GitHub release and unzips it, so no build needs to be bundled.
# WORKER_SERVER_URL is how the worker reaches the server (internal name in Docker,
# or a public URL when running a worker on another machine).
WORKER_SERVER_URL=http://server:5050
WORKER_NAME=worker
# Max Godot processes a single worker runs in parallel (set per machine).
WORKER_MAX_JOBS=4
# Release to download the dedicated-server build from ("latest" or a tag like 0.0.4).
GODOT_RELEASE_TAG=latest
# Optional: set GODOT_SERVER_BIN to a mounted binary to skip the download.
GODOT_SERVER_BIN=
GODOT_PCK=
EVAL_TIMEOUT_SECONDS=1800
EVAL_FIXED_FPS=60
